{
  "name": "@recipes/server",
  "version": "0.1.4",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "generate:recipes": "node --import tsx scripts/generate-recipes.ts",
    "simulate:game": "node --import tsx scripts/simulate-game.ts",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@fastify/websocket": "^11.0.2",
    "fastify": "^5.6.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
