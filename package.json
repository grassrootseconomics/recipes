{
  "name": "recipes",
  "version": "0.1.0",
  "private": true,
  "description": "Authoritative multiplayer recipe trading MVP.",
  "workspaces": [
    "server"
  ],
  "scripts": {
    "dev": "npm --workspace server run dev",
